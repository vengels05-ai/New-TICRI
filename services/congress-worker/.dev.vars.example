# Copy to .dev.vars for local wrangler dev
CONGRESS_API_KEY=replace_with_congress_api_key
CONGRESS_ADMIN_TOKEN=replace_with_admin_token
# Optional overrides:
# CORS_ALLOWED_ORIGINS=https://ticri.org,https://www.ticri.org,http://localhost:3000
# MAX_DATE_RANGE_DAYS=366
# MAX_KEYWORD_LENGTH=200
# SEARCH_DEFAULT_LIMIT=20
# SEARCH_MAX_LIMIT=100
# CONGRESS_API_BASE_URL=https://api.congress.gov/v3
# CONGRESS_API_THROTTLE_MS=250
# CONGRESS_API_MAX_REQUESTS_PER_MINUTE=120
# CONGRESS_UPSTREAM_CACHE_TTL_MS=300000
# CONGRESS_INGEST_ENABLED=true
# CONGRESS_INGEST_CONGRESS=119
# CONGRESS_INGEST_WINDOW_DAYS=7
# CONGRESS_INGEST_MAX_PAGES=25
# CONGRESS_INGEST_MAX_ACTION_PAGES=25
# CONGRESS_BACKFILL_ENABLED=false
# CONGRESS_BACKFILL_ALLOW_PRODUCTION=false
# CONGRESS_BACKFILL_MAX_PAGES_PER_RUN=10
# APP_ENV=development
